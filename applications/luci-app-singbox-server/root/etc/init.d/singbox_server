#!/bin/sh /etc/rc.common

. /lib/functions.sh
. /lib/functions/procd.sh

START=99
STOP=10
USE_PROCD=1

CONFIG=singbox_server
BIN=/usr/bin/sing-box
GEN=/usr/share/singbox-server/singbox-server.sh
RUNDIR=/tmp/etc/singbox_server
MAINLOG=/tmp/log/singbox_server.log

append_log() {
	mkdir -p /tmp/log
	echo "$(date '+%Y-%m-%d %H:%M:%S'): $*" >> "$MAINLOG"
}

clear_logs() {
	mkdir -p /tmp/log
	: > "$MAINLOG"
	rm -f /tmp/log/singbox_server_*.log
}

check_config() {
	local conf="$1" tmp="/tmp/singbox_server_check.$$"
	# 按要求恢复原始方式：sing-box check -c <file>
	if "$BIN" check -c "$conf" >"$tmp" 2>&1; then
		rm -f "$tmp"
		return 0
	fi
	cat "$tmp" >> "$MAINLOG"
	rm -f "$tmp"
	return 1
}

start_service() {
	clear_logs
	append_log "清空旧日志"
	config_load "$CONFIG"
	local global_enabled
	config_get_bool global_enabled global enabled 0
	[ "$global_enabled" = "1" ] || { append_log "全局未启用，跳过启动"; return 0; }
	[ -x "$BIN" ] || { append_log "未找到 sing-box：$BIN"; return 1; }
	mkdir -p "$RUNDIR" /tmp/log
	config_foreach start_instance server
}

start_instance() {
	local section="$1"
	local enabled remarks log conf listen_port
	config_get_bool enabled "$section" enabled 0
	[ "$enabled" = "1" ] || return 0
	config_get remarks "$section" remarks "$section"
	config_get_bool log "$section" log 0
	config_get listen_port "$section" listen_port ""
	conf="$RUNDIR/$section.json"
	: > "/tmp/log/singbox_server_${section}.log"

	$GEN gen "$section" "$conf" || { append_log "$remarks 生成配置文件失败"; return 1; }
	append_log "$remarks 生成配置文件并运行 - $conf"

	# 先检查配置，失败时把错误写入主日志，避免 LuCI 只显示“未运行”。
	if check_config "$conf"; then
		append_log "$remarks 配置检查通过"
	else
		append_log "$remarks 配置检查失败，请查看上方 sing-box 错误"
		return 1
	fi

	procd_open_instance "$section"
	procd_set_param command "$BIN" run -c "$conf"
	procd_set_param respawn 3600 5 5
	procd_set_param file "/etc/config/$CONFIG"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	append_log "停止所有 sing-box 服务端实例"
}

reload_service() {
	append_log "重新加载配置并热重载实例"
	restart
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
