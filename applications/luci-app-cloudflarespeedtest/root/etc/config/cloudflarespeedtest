config global 'global'
        option enabled '0'
        option ipv6_enabled '1'
        option advanced '1'
        option custome_url 'https://speedtest.poorhub.pro/cf.7z'
        option speed '0'
        option custome_cors_enabled '1'
        option proxy_mode 'nil'
        option threads '200'
        option tl '185'
        option tll '20'
        option t '4'
        option dt '5'
        option dn '1'
        option dd '0'
        option tp '443'
        option custome_cron '27 */2 * * *'


config servers 'servers'
	option ssr_enabled '0'
	option passwall_enabled '0'
	option passwall2_enabled '0'
	option bypass_enabled '0'
	option vssr_enabled '0'
	option DNS_enabled '0'

